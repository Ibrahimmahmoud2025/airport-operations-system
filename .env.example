# Build-time / Vercel: injected into public-config.js by `npm run build`
DATA_SOURCE=local
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_LOGISTICS_AUTH_EMAIL_SUFFIX=@users.logistics.local

# Server-only (Vercel → api/create-user.js). Never expose in the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
LOGISTICS_AUTH_EMAIL_SUFFIX=@users.logistics.local
